<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/textAppTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Droid Mod Loader"
        android:textSize="24sp"
        android:textStyle="bold"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/textVersionLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Version 0.1 Beta"
        android:textSize="14sp"
        android:paddingBottom="12dp" />

    <TextView
        android:id="@+id/summaryTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingTop="4dp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/summaryTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Summary will appear here."
        android:textSize="14sp"
        android:paddingBottom="12dp" />

    <Button
        android:id="@+id/buttonRefreshDashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Refresh Dashboard" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/installedModsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mods"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/buttonImportZip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Import Archive" />

            <Button
                android:id="@+id/buttonRefreshModsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Refresh Mods" />

            <LinearLayout
                android:id="@+id/installedModsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/pluginsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plugins"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/buttonSaveDiscoveredPlugins"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Discover Plugins" />

            <Button
                android:id="@+id/buttonRefreshPluginsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Refresh Plugins" />

            <Button
                android:id="@+id/buttonExportPluginOutputs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Export Plugin Outputs" />

            <LinearLayout
                android:id="@+id/pluginsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/workflowTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Deployment And Settings"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerGameConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/editTargetPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Target Data Path" />

            <TextView
                android:id="@+id/textSelectedTreeUri"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selected folder URI: none"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/buttonPickTargetFolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pick Target Folder" />

            <CheckBox
                android:id="@+id/checkRealDeployEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Real Deploy" />

            <Button
                android:id="@+id/buttonLoadSelectedGameConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Load Selected Game Config" />

            <Button
                android:id="@+id/buttonSaveSelectedGameConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Selected Game Config" />

            <Button
                android:id="@+id/buttonDeployCurrentState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Deploy Current State" />

            <Button
                android:id="@+id/buttonDeploySkyrim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Deploy Skyrim" />

            <Button
                android:id="@+id/buttonResetAppData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reset App Data" />

            <TextView
                android:id="@+id/textReportSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Report And Diagnostics"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/buttonCopyDiagnosticSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Copy Diagnostic Summary" />

            <Button
                android:id="@+id/buttonShareLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Share Logs" />

            <TextView
                android:id="@+id/logTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:text="Log output will appear here..."
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/developerToolsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Developer Tools"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <Button
                    android:id="@+id/buttonDeleteModTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Delete Mod Test" />

                <Button
                    android:id="@+id/buttonSmokeTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Smoke Test" />

                <Button
                    android:id="@+id/buttonPathUtilsTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run PathUtils Test" />

                <Button
                    android:id="@+id/buttonScannerTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Scanner Test" />

                <Button
                    android:id="@+id/buttonConflictTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Conflict Test" />

                <Button
                    android:id="@+id/buttonStagingTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Staging Test" />

                <Button
                    android:id="@+id/buttonDiffTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Diff Test" />

                <Button
                    android:id="@+id/buttonStateTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Mod State Test" />

                <Button
                    android:id="@+id/buttonEngineTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Engine Test" />

                <Button
                    android:id="@+id/buttonInstalledRecordTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Installed Record Test" />

                <Button
                    android:id="@+id/buttonDeployScopeTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Deploy Scope Test" />

                <Button
                    android:id="@+id/buttonDeploymentManifestTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Deployment Manifest Test" />

                <Button
                    android:id="@+id/buttonGameTargetTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Game Target Test" />

                <Button
                    android:id="@+id/buttonGameConfigEditorTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Game Config Editor Test" />

                <Button
                    android:id="@+id/buttonTargetFolderPickerTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Target Folder Picker Test" />

                <Button
                    android:id="@+id/buttonTreeUriDeployTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Tree URI Deploy Test" />

                <Button
                    android:id="@+id/buttonArchiveExtractorTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Archive Extractor Test" />

                <Button
                    android:id="@+id/buttonPluginDiscoveryTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Plugin Discovery Test" />

                <Button
                    android:id="@+id/buttonPluginEditTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Plugin Edit Test" />

                <Button
                    android:id="@+id/buttonPluginOutputTest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Plugin Output Test" />

                <Button
                    android:id="@+id/buttonListInstalledMods"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="List Installed Mods" />

                <Button
                    android:id="@+id/buttonSaveInstalledMods"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Save Installed Mods" />

                <Button
                    android:id="@+id/buttonLoadSavedMods"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Load Saved Mods" />

                <Button
                    android:id="@+id/buttonRebuildInstalledStaging"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rebuild Staging From Installed Mods" />

                <Button
                    android:id="@+id/buttonInstallArchiveWorkflow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Install Test Archive Mod" />

                <Button
                    android:id="@+id/buttonInstallLooseWorkflow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Install Loose Test Mods" />

                <Button
                    android:id="@+id/buttonSaveGameConfig"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Save Game Configs" />

                <Button
                    android:id="@+id/buttonLoadGameConfig"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Load Game Configs" />

                <Button
                    android:id="@+id/buttonClearLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Clear Log" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>